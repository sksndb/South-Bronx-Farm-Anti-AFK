-- Uptime timer
local startTime = tick()
spawn(function()
    while screenGui.Parent do
        wait(0.5)
        local elapsed = tick() - startTime
        local h = math.floor(elapsed / 3600)
        local m = math.floor((elapsed % 3600) / 60)
        local s = math.floor(elapsed % 60)
        timerLabel.Text = string.format("%02d:%02d:%02d", h, m, s)
    end
end)

-- Detector farm parado (si char no mueve >5min, walk invisible)
local lastPos = Vector3.new(0,0,0)
local idleStart = tick()
local char = player.CharacterAdded:Wait():WaitForChild("HumanoidRootPart")
player.CharacterAdded:Connect(function(newChar)
    char = newChar:WaitForChild("HumanoidRootPart")
end)
spawn(function()
    while true
        wait(5)  -- Chequeo cada 5s
        if char and char.Parent then
            local currPos = char.Position
            if (currPos - lastPos).Magnitude < 1 then  -- No movió >1 stud
                local idleTime = tick() - idleStart
                if idleTime > 300 then  -- >5 min parado
                    farmStatus.Text = "Farm: Parado - Fix"
                    farmStatus.TextColor3 = Color3.fromRGB(255, 200, 100)
                    -- Walk invisible (solo tiembla 1px)
                    char.CFrame = char.CFrame + Vector3.new(math.random(-1,1)/10, 0, math.random(-1,1)/10)
                    wait(0.1)
                    idleStart = tick()
                end
            else
                lastPos = currPos
                idleStart = tick()
                farmStatus.Text = "Farm: Activo"
                farmStatus.TextColor3 = Color3.fromRGB(200, 255, 200)
            end
        end
    end
end)

