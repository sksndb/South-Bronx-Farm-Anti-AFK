local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- GUI simple en PlayerGui
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AntiAFK_Bronx_Lite"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 220, 0, 70)
frame.Position = UDim2.new(1, -230, 0, 20)
frame.BackgroundColor3 = Color3.fromRGB(15, 15, 30)
frame.BorderSizePixel = 0
frame.Parent = screenGui

local uicorner = Instance.new("UICorner")
uicorner.CornerRadius = UDim.new(0, 12)
uicorner.Parent = frame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -20, 0, 25)
title.Position = UDim2.new(0, 10, 0, 5)
title.BackgroundTransparency = 1
title.Text = "🛡️ Anti-AFK"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.TextScaled = true
title.Font = Enum.Font.GothamBold
title.Parent = frame

local timerLabel = Instance.new("TextLabel")
timerLabel.Size = UDim2.new(1, -20, 0, 25)
timerLabel.Position = UDim2.new(0, 10, 0, 30)
timerLabel.BackgroundTransparency = 1
timerLabel.Text = "00:00:00"
timerLabel.TextColor3 = Color3.fromRGB(150, 220, 255)
timerLabel.TextScaled = true
timerLabel.Font = Enum.Font.GothamSemibold
timerLabel.Parent = frame

-- Timer uptime
local startTime = tick()
spawn(function()
    while screenGui.Parent do
        wait(1)  -- Cada segundo pa' no laggear
        local elapsed = tick() - startTime
        local h = math.floor(elapsed / 3600)
        local m = math.floor((elapsed % 3600) / 60)
        local s = math.floor(elapsed % 60)
        timerLabel.Text = string.format("%02d:%02d:%02d", h, m, s)
    end
end)

-- Bloqueo kick principal (Idled)
player.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
    print("¡Kick bloqueado! Sigue AFK tranqui 🔥")
    -- Opcional: cambia status si quieres, pero sin flash pa' evitar crash
end)

spawn(function()
    while true do
        wait(600)  -- cada 10 min
        game.Players.LocalPlayer.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        print("Jump backup cada 10 min pa' extra seguridad")
    end
end)

print("🛡️ Anti-AFK Bronx Lite cargado! Cuadro arriba derecha + timer subiendo. Olvídate del kick forever 🇩🇴")
