-- Temporizador bonito
local startTime = tick()
spawn(function()
    while screenGui.Parent do
        wait(0.5)
        local elapsed = tick() - startTime
        local h = math.floor(elapsed / 3600)
        local m = math.floor((elapsed % 3600) / 60)
        local s = math.floor(elapsed % 60)
        timerLabel.Text = string.format("%02d:%02d:%02d", h, m, s)
    end
end)

-- Anti-AFK PERECTO (solo actúa cuando Roblox va a kickear)
player.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
    
    -- Efecto flash y status
    statusLabel.Text = "¡Kick bloqueado!"
    statusLabel.TextColor3 = Color3.fromRGB(255, 150, 150)
    TweenService:Create(frame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(50, 10, 10)}):Play()
    wait(0.2)
    TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Back), {BackgroundColor3 = Color3.fromRGB(15, 15, 30)}):Play()
    wait(2)
    statusLabel.Text = "Status: Activo"
    statusLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
end)

-- Toggle con Insert (opcional)
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.Insert then
        screenGui.Enabled = not screenGui.Enabled
    end
end)
